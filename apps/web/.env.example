# Public base URL of this site. Used for canonical links and SEO.
NUXT_PUBLIC_SITE_URL=

# The deployed API base URL (sst output `api`). The "Add to Slack" button links
# to $BASE/slack/install and the demo chat widget POSTs to $BASE/chat.
# Empty hides the chat widget and disables the install button.
NUXT_PUBLIC_BASE_URL=
