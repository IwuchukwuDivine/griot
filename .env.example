# Slack app credentials (https://api.slack.com/apps → your app)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# LLM — Gemini is the primary provider ("bedrock" exists behind the flag but is not enabled)
GEMINI_API_KEY=
LLM_PROVIDER=gemini
GEMINI_SMART_MODEL=gemini-2.5-flash
GEMINI_FAST_MODEL=gemini-2.5-flash-lite

# CockroachDB connection string (Cloud console → Connect)
DATABASE_URL=postgresql://<user>:<password>@<host>:26257/<database>?sslmode=verify-full

# AWS (deploys only)
AWS_REGION=eu-west-2

# Team timezone — todo deadlines, daily summary, and deadline check all resolve dates here
TZ=Africa/Lagos

# Optional: pino log level (default info)
LOG_LEVEL=info

KNOWLEDGE_MIN_SIMILARITY=0.65

# Public web-chat demo — the landing-page widget answers (read-only) from this workspace
DEMO_WORKSPACE_ID=griot-web-demo
# Global daily message cap across all demo visitors
CHAT_DAILY_CAP=500
