# Slack app credentials (https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# LLM — Gemini is the primary provider ("bedrock" exists behind the flag but is not enabled)
GEMINI_API_KEY=
LLM_PROVIDER=gemini
GEMINI_SMART_MODEL=gemini-2.5-flash
GEMINI_FAST_MODEL=gemini-2.5-flash-lite

# CockroachDB serverless connection string
DATABASE_URL=postgresql://<user>:<password>@<host>:26257/<database>?sslmode=verify-full

# AWS
AWS_REGION=eu-west-2
TZ=Africa/Lagos
